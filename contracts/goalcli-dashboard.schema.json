{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xlib-standard.local/contracts/goalcli-dashboard.schema.json",
  "title": "goalcli dashboard",
  "type": "object",
  "required": ["schema_version", "command", "status", "matrix", "scope", "mode", "write_evidence", "components"],
  "properties": {
    "schema_version": {"type": "string", "enum": ["1.0"]},
    "command": {"type": "string", "const": "dashboard-generate"},
    "status": {"type": "string", "enum": ["passed", "failed"]},
    "goal_id": {"type": "string", "minLength": 1},
    "matrix": {"type": "string", "minLength": 1},
    "scope": {
      "type": "array",
      "items": {"type": "string", "enum": ["goal", "req", "task", "issue", "evidence", "release"]},
      "minItems": 6,
      "maxItems": 6
    },
    "mode": {"type": "string", "const": "local-readonly"},
    "write_evidence": {"type": "boolean", "const": false},
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["passed", "failed"]},
          "summary": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "gaps": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
