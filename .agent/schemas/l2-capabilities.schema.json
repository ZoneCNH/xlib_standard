{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xlib-standard.local/schemas/l2-capabilities.schema.json",
  "title": "L2 Capability Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "layer",
    "adapter",
    "capabilities",
    "contract_packs",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "layer": {
      "const": "L2"
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "module",
        "family"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "module": {
          "type": "string",
          "minLength": 1
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "owners": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "family",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "family": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "declared",
              "implemented",
              "unsupported",
              "deprecated"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "contract_packs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_profiles",
        "output_dir"
      ],
      "properties": {
        "required_profiles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "output_dir": {
          "type": "string",
          "minLength": 1
        },
        "reports": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
