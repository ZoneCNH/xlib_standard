{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xlib-standard.local/schemas/l2-compliance-matrix.schema.json",
  "title": "L2 Compliance Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter",
    "rows"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "adapter": {
      "type": "string",
      "minLength": 1
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requirement",
          "contract_pack",
          "profile",
          "evidence",
          "status"
        ],
        "properties": {
          "requirement": {
            "type": "string"
          },
          "contract_pack": {
            "type": "string"
          },
          "profile": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "status": {
            "enum": [
              "pass",
              "fail",
              "missing",
              "not_applicable"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
