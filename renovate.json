{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "gomod",
    "github-actions"
  ],
  "automerge": false,
  "dependencyDashboard": true,
  "prConcurrentLimit": 4,
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "description": "Keep Go module updates small and reviewable.",
      "matchManagers": [
        "gomod"
      ],
      "groupName": "go module dependencies",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "addLabels": [
        "go",
        "dependency-review"
      ]
    },
    {
      "description": "Keep GitHub Actions updates separate from Go module changes.",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions dependencies",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "addLabels": [
        "github-actions",
        "dependency-review"
      ]
    },
    {
      "description": "Major updates require explicit human review.",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "dependencyDashboardApproval": true,
      "addLabels": [
        "major",
        "needs-human-review"
      ]
    },
    {
      "description": "Standard, contract, generator, and harness surfaces require review.",
      "matchFileNames": [
        "contracts/**",
        "docs/standard/**",
        "scripts/**",
        "cmd/goalcli/**",
        "internal/tools/**",
        "release/manifest/template.json"
      ],
      "automerge": false,
      "addLabels": [
        "standard-governance",
        "needs-human-review"
      ]
    }
  ]
}
